{
  "expo": {
    "name": "BloodAI",
    "slug": "ai-blood-report-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "bloodai",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0414"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bloodai.app",
      "infoPlist": {
        "NSMotionUsageDescription": "FitHealth AI uses motion data to automatically count your daily steps."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0a0414"
      },
      "package": "com.bloodai.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "ACTIVITY_RECOGNITION"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow BloodAI to access your photos to upload blood reports.",
          "cameraPermission": "Allow BloodAI to use your camera to photograph blood reports."
        }
      ],
      "expo-document-picker",
      "expo-asset",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow FitHealth AI to access your location to show air quality for your area."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Allow FitHealth AI to track your steps automatically using your device's motion sensor."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
